{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Leadey",
  "colors": {
    "primary": "#4A5478",
    "light": "#97A4D6",
    "dark": "#242E55"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "DM Sans"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#F4F5F9",
      "dark": "#0C1122"
    },
    "decoration": "gradient"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "python", "javascript"]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "guides/signals",
              "guides/icps",
              "guides/campaigns",
              "guides/credits"
            ]
          },
          {
            "group": "Using the API",
            "pages": [
              "guides/authentication",
              "guides/errors",
              "guides/pagination",
              "guides/rate-limits"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "guides/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "href": "https://leadey.ai",
          "icon": "house"
        },
        {
          "anchor": "Dashboard",
          "href": "https://app.leadey.ai",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logomark-color.svg",
    "dark": "/logo/logomark-white.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@leadey.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://app.leadey.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/leadey",
      "linkedin": "https://linkedin.com/company/leadey"
    }
  }
}
